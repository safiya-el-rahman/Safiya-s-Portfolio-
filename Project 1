# THE DATA ARCHIVE: Jedi Archives Theme
class Holocron:
    def __init__(self, jedi_author, wisdom_text):
        self.jedi_author = jedi_author
        self.wisdom_text = wisdom_text

def main():
    # This list will store our Holocron objects
    archive = []
    
    keep_going = True
    while keep_going:
        print("\nCommands: new, remove, print, quit")
        user_input = input("Enter a command: ")
        
        if user_input == "new":
            author = input("Enter the Jedi author: ")
            text = input("Enter the wisdom text: ")
            # Create the object and add it to the list
            new_entry = Holocron(author, text)
            archive.append(new_entry)
            print("Entry added to the archive.")
            
        elif user_input == "remove":
            if len(archive) > 0:
                # Removes the last item added to the list
                archive.pop()
                print("Last entry removed.")
            else:
                print("Archive is already empty.")
                
        elif user_input == "print":
            print("\n--- Current Archive Records ---")
            for item in archive:
                print("Author:", item.jedi_author, "| Wisdom:", item.wisdom_text)
                
        elif user_input == "quit":
            print("May the Code be with you.")
            keep_going = False
            
        else:
            print("Invalid command. Please try again.")

if __name__ == "__main__":
    main()
